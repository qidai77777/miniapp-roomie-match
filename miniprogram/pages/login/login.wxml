<navigation-bar title="拼室友" back="{{false}}" color="#164e63" background="rgba(255,255,255,0.88)"></navigation-bar>

<view class="login-page">
  <view class="bg-orb orb-a"></view>
  <view class="bg-orb orb-b"></view>

  <view class="login-card">
    <view class="brand-chip">RoomieMatch</view>
    <view class="title">进入小程序前需要先登录</view>
    <view class="subtitle">当前环境：{{envLabel}}。系统会先完成微信登录，再获取你的头像和昵称。</view>

    <view class="status-panel {{loading ? 'loading' : ''}}">
      <view class="status-dot"></view>
      <text>{{loading ? '正在处理中...' : (needsProfile ? '请授权头像和昵称' : '登录未完成')}}</text>
    </view>

    <view wx:if="{{errorMessage}}" class="error-box">{{errorMessage}}</view>

    <view wx:if="{{needsProfile}}" class="profile-panel">
      <view wx:if="{{avatarUrl}}" class="avatar-wrap">
        <image class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
      </view>
      <view wx:if="{{nickName}}" class="nickname-text">{{nickName}}</view>
      <view class="profile-tip">点击下方按钮授权微信头像和昵称，授权完成后自动进入首页。</view>

      <button class="retry-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="handleGetUserProfile">
        {{loading ? '获取中...' : '获取头像和昵称'}}
      </button>
    </view>

    <button wx:else class="retry-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="handleRetry">
      {{loading ? '登录中...' : '重新登录'}}
    </button>
  </view>
</view>
