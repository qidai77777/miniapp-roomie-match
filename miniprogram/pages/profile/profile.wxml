<navigation-bar title="坡岛合租工具" back="{{false}}" color="#164e63" background="rgba(255,255,255,0.88)"></navigation-bar>

<scroll-view class="page-scroll" scroll-y="{{true}}">
  <view class="page-shell">
    <view class="bg-orb orb-a"></view>
    <view class="bg-orb orb-b"></view>

    <view class="profile-card">
      <view class="profile-hero">
        <view class="hero-user">
          <view class="hero-avatar-frame">
            <view class="hero-avatar-ring"></view>
            <image wx:if="{{profile.avatarUrl}}" class="hero-avatar" src="{{profile.avatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="hero-avatar hero-avatar-placeholder">R</view>
          </view>
          <view class="hero-user-copy">
            <view class="hero-nickname">{{profile.nickName || '未授权昵称'}}</view>
          </view>
        </view>
        <view class="profile-title">你的坡岛合租档案</view>
      </view>

      <view class="profile-grid">
        <view wx:if="{{!hasRequiredProfile}}" class="profile-alert">
          <text class="profile-alert-title">基础资料未完善</text>
          <text class="profile-alert-text">请先补全{{missingText}}，这些字段会影响后续匹配提交。</text>
        </view>

        <view class="profile-panel">
          <view class="panel-head">
            <view>
              <view class="panel-title">基础资料</view>
            </view>
          </view>

          <view class="field-group">
            <view class="field-label">性别 <text class="required">*</text></view>
            <view class="radio-group">
              <view class="radio-btn {{profile.gender === 'male' ? 'selected' : ''}}" data-value="male" bindtap="selectGender">男生</view>
              <view class="radio-btn {{profile.gender === 'female' ? 'selected' : ''}}" data-value="female" bindtap="selectGender">女生</view>
            </view>
          </view>

          <view class="field-group">
            <view class="field-label">年龄</view>
            <view class="age-wrap">
              <input class="field-input" type="number" value="{{profile.age}}" placeholder="请输入年龄" bindinput="onAgeInput" />
              <view class="age-unit">岁</view>
            </view>
          </view>

          <view class="field-group">
            <view class="field-label">学校 <text class="required">*</text></view>
            <picker mode="selector" range="{{schoolOptions}}" range-key="label" bindchange="onSchoolChange">
              <view class="field-select {{profile.school ? '' : 'placeholder'}}">{{schoolDisplayText || '请选择学校'}}</view>
            </picker>
          </view>

          <view class="field-group">
            <view class="field-label">微信号 <text class="required">*</text></view>
            <input class="field-input" value="{{profile.wechat}}" maxlength="50" placeholder="请输入你的微信号" bindinput="onWechatInput" />
          </view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<view class="bottom-tab">
  <view class="tab-link" bindtap="goHome">
    <view class="tab-icon icon-home"></view>
  </view>
  <view class="tab-link active">
    <view class="tab-icon icon-profile"></view>
  </view>
</view>
